{
  "name": "elliott-trading-system",
  "version": "1.0.0",
  "description": "Sistema de trading basado en Ondas de Elliott y entradas por capas",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "backtest": "node scripts/runBacktest.js",
    "test": "node --test",
    "docs": "jsdoc -c jsdoc.json",
    "docs:md": "documentation build \"src/**/*.js\" -f md -o DOCUMENTACION_TECNICA.md",
    "docs:pdf": "md-to-pdf DOCUMENTACION_TECNICA.md"
  },
  "keywords": [
    "trading",
    "elliott",
    "waves",
    "backtesting"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "technicalindicators": "^3.1.0"
  },
  "devDependencies": {
    "documentation": "^14.0.3",
    "jsdoc": "^4.0.5",
    "md-to-pdf": "^5.2.5",
    "nodemon": "^3.1.9"
  }
}
